rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == "princeteah200@gmail.com";
    }

    function userProfileExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserProfile() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function isActiveUser() {
      return isSignedIn()
        && userProfileExists()
        && (
          !currentUserProfile().keys().hasAny(["suspended"])
          || currentUserProfile().suspended != true
        );
    }

    function validRating() {
      return request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
    }

    // ==================================================
    // USERS
    // ==================================================

    match /users/{userId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.verified == false
        && request.resource.data.businessVerified == false
        && request.resource.data.suspended == false
        && (
          request.resource.data.role == "user"
          || (isAdmin() && request.resource.data.role == "admin")
        );

      allow update: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid == userId
          && !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              "verified",
              "businessVerified",
              "suspended",
              "role",
              "email"
            ])
        );

      allow delete: if isAdmin();
    }

    // ==================================================
    // PRODUCTS / LISTINGS
    // ==================================================

    match /products/{productId} {
      allow read: if true;

      allow create: if isActiveUser()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.sellerEmail == request.auth.token.email
        && request.resource.data.status in ["active", "pending_review"]
        && request.resource.data.featured != true
        && (
          !request.resource.data.keys().hasAny(["boostStatus"])
          || request.resource.data.boostStatus in ["none", "expired"]
        );

      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.sellerId == request.auth.uid
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.sellerEmail == resource.data.sellerEmail

          // Sellers cannot directly activate or approve a paid boost.
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              "featured",
              "boostActivatedAt",
              "boostExpiresAt",
              "boostExpiredAt"
            ])
            || (
              request.resource.data.featured == false
              && request.resource.data.boostStatus in ["expired", "rejected", "none"]
            )
          )

          // Sellers may submit a request, but cannot mark it active themselves.
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              "boostStatus"
            ])
            || request.resource.data.boostStatus in [
              resource.data.boostStatus,
              "pending",
              "expired",
              "none"
            ]
          )

          // A listing under admin review stays under review until admin acts.
          && (
            resource.data.status != "pending_review"
            || request.resource.data.status == "pending_review"
          )
        );

      allow delete: if isAdmin()
        || (
          isActiveUser()
          && resource.data.sellerId == request.auth.uid
        );
    }

    // ==================================================
    // CHATS / CONVERSATIONS
    // ==================================================

    match /chats/{chatId} {
      // A signed-in, active user may create a private chat only when:
      // 1. Their UID is included in participants.
      // 2. Exactly two unique participants are supplied.
      // 3. The buyer and seller are different users when those fields exist.
      allow create: if isActiveUser()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants[0] != request.resource.data.participants[1]
        && (
          !request.resource.data.keys().hasAny(["buyerId"])
          || (
            request.resource.data.buyerId is string
            && request.resource.data.buyerId in request.resource.data.participants
          )
        )
        && (
          !request.resource.data.keys().hasAny(["sellerId"])
          || (
            request.resource.data.sellerId is string
            && request.resource.data.sellerId in request.resource.data.participants
          )
        )
        && (
          !request.resource.data.keys().hasAll(["buyerId", "sellerId"])
          || request.resource.data.buyerId != request.resource.data.sellerId
        );

      // Only the two participants and the admin may open a chat.
      allow read: if isAdmin()
        || (
          isActiveUser()
          && resource.data.participants is list
          && request.auth.uid in resource.data.participants
        );

      // Participants may update chat metadata, but they cannot change
      // the chat participants, buyer, seller, product, or creator identity.
      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.participants is list
          && request.auth.uid in resource.data.participants
          && request.resource.data.participants == resource.data.participants
          && (
            !resource.data.keys().hasAny(["buyerId"])
            || request.resource.data.buyerId == resource.data.buyerId
          )
          && (
            !resource.data.keys().hasAny(["sellerId"])
            || request.resource.data.sellerId == resource.data.sellerId
          )
          && (
            !resource.data.keys().hasAny(["productId"])
            || request.resource.data.productId == resource.data.productId
          )
          && (
            !resource.data.keys().hasAny(["createdBy"])
            || request.resource.data.createdBy == resource.data.createdBy
          )
          && (
            !resource.data.keys().hasAny(["createdAt"])
            || request.resource.data.createdAt == resource.data.createdAt
          )
        );

      allow delete: if isAdmin();
    }

    // Support projects that use "conversations" instead of "chats".
    match /conversations/{conversationId} {
      allow create: if isActiveUser()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants[0] != request.resource.data.participants[1];

      allow read: if isAdmin()
        || (
          isActiveUser()
          && resource.data.participants is list
          && request.auth.uid in resource.data.participants
        );

      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.participants is list
          && request.auth.uid in resource.data.participants
          && request.resource.data.participants == resource.data.participants
          && (
            !resource.data.keys().hasAny(["buyerId"])
            || request.resource.data.buyerId == resource.data.buyerId
          )
          && (
            !resource.data.keys().hasAny(["sellerId"])
            || request.resource.data.sellerId == resource.data.sellerId
          )
          && (
            !resource.data.keys().hasAny(["productId"])
            || request.resource.data.productId == resource.data.productId
          )
          && (
            !resource.data.keys().hasAny(["createdBy"])
            || request.resource.data.createdBy == resource.data.createdBy
          )
          && (
            !resource.data.keys().hasAny(["createdAt"])
            || request.resource.data.createdAt == resource.data.createdAt
          )
        );

      allow delete: if isAdmin();
    }

    // ==================================================
    // MESSAGES
    // ==================================================

    match /messages/{messageId} {
      allow create: if isActiveUser()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] != request.resource.data.participants[1]
        && request.resource.data.participants.hasAll([
          request.resource.data.senderId,
          request.resource.data.receiverId
        ])
        && (
          !request.resource.data.keys().hasAny(["chatId"])
          || (
            request.resource.data.chatId is string
            && (
              (
                exists(
                  /databases/$(database)/documents/chats/$(request.resource.data.chatId)
                )
                && request.auth.uid in get(
                  /databases/$(database)/documents/chats/$(request.resource.data.chatId)
                ).data.participants
              )
              ||
              (
                exists(
                  /databases/$(database)/documents/conversations/$(request.resource.data.chatId)
                )
                && request.auth.uid in get(
                  /databases/$(database)/documents/conversations/$(request.resource.data.chatId)
                ).data.participants
              )
            )
          )
        );

      allow read: if isAdmin()
        || (
          isActiveUser()
          && resource.data.participants is list
          && request.auth.uid in resource.data.participants
        );

      // A participant may only mark a message as read.
      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.participants is list
          && request.auth.uid in resource.data.participants
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.receiverId == resource.data.receiverId
          && request.resource.data.participants == resource.data.participants
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly(["read", "readAt"])
        );

      allow delete: if isAdmin();
    }

    // ==================================================
    // REVIEWS
    // ==================================================

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isActiveUser()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.sellerId is string
        && request.resource.data.sellerId != request.auth.uid
        && validRating();

      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.reviewerId == request.auth.uid
          && request.resource.data.reviewerId == resource.data.reviewerId
          && request.resource.data.sellerId == resource.data.sellerId
          && validRating()
          && !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              "orderId",
              "productId",
              "reviewerId",
              "sellerId",
              "verifiedPurchase"
            ])
        );

      allow delete: if isAdmin()
        || (
          isActiveUser()
          && resource.data.reviewerId == request.auth.uid
        );
    }

    // ==================================================
    // FOLLOWERS
    // ==================================================

    match /followers/{followId} {
      allow read: if true;

      allow create: if isActiveUser()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.sellerId is string
        && request.resource.data.sellerId != request.auth.uid
        && followId == request.resource.data.sellerId + "_" + request.auth.uid
        && request.resource.data.keys().hasOnly([
          "sellerId",
          "followerId",
          "createdAt"
        ]);

      allow update: if false;

      allow delete: if isAdmin()
        || (
          isActiveUser()
          && resource.data.followerId == request.auth.uid
        );
    }

    // ==================================================
    // REPORTS
    // ==================================================

    match /reports/{reportId} {
      allow create: if isActiveUser()
        && request.resource.data.status == "pending"
        && (
          (
            request.resource.data.keys().hasAll([
              "userId",
              "fullName",
              "email",
              "reportType",
              "description",
              "status",
              "createdAt"
            ])
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.description is string
            && request.resource.data.description.size() > 0
          )
          ||
          (
            request.resource.data.keys().hasAll([
              "reporterId",
              "sellerId",
              "status"
            ])
            && request.resource.data.reporterId == request.auth.uid
            && request.resource.data.sellerId != request.auth.uid
          )
        );

      allow read, update, delete: if isAdmin();
    }

    // ==================================================
    // WISHLISTS
    // ==================================================

    match /wishlists/{userId}/items/{itemId} {
      allow read, create, update, delete: if isActiveUser()
        && request.auth.uid == userId;
    }

    // ==================================================
    // NOTIFICATIONS
    // ==================================================

    match /notifications/{notificationId} {
      allow create: if isActiveUser()
        && request.resource.data.userId is string
        && (
          !request.resource.data.keys().hasAny(["senderId"])
          || request.resource.data.senderId == request.auth.uid
        );

      allow read: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid == resource.data.userId
        );

      allow update: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid == resource.data.userId
          && request.resource.data.userId == resource.data.userId
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly(["read", "readAt"])
        );

      allow delete: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid == resource.data.userId
        );
    }

    // ==================================================
    // ORDERS
    // ==================================================

    match /orders/{orderId} {
      allow create: if isActiveUser()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.sellerId is string
        && request.resource.data.sellerId != request.auth.uid
        && request.resource.data.status == "pending";

      allow read: if isAdmin()
        || (
          isActiveUser()
          && (
            request.auth.uid == resource.data.buyerId
            || request.auth.uid == resource.data.sellerId
          )
        );

      allow update: if isAdmin()

        // Buyer may cancel a pending order or add review markers.
        || (
          isActiveUser()
          && request.auth.uid == resource.data.buyerId
          && request.resource.data.buyerId == resource.data.buyerId
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              "status",
              "cancelledAt",
              "cancelReason",
              "reviewSubmitted",
              "reviewId",
              "reviewedAt"
            ])
          && (
            (
              resource.data.status == "pending"
              && request.resource.data.status == "cancelled"
            )
            ||
            request.resource.data.status == resource.data.status
          )
        )

        // Seller may change only order-processing fields.
        || (
          isActiveUser()
          && request.auth.uid == resource.data.sellerId
          && request.resource.data.buyerId == resource.data.buyerId
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              "status",
              "confirmedAt",
              "completedAt",
              "cancelledAt",
              "cancelReason",
              "sellerNote"
            ])
          && (
            (
              resource.data.status == "pending"
              && request.resource.data.status in ["confirmed", "cancelled"]
            )
            ||
            (
              resource.data.status == "confirmed"
              && request.resource.data.status in ["completed", "cancelled"]
            )
          )
        );

      allow delete: if isAdmin();
    }

    // ==================================================
    // MARKETPLACE SETTINGS
    // ==================================================

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ==================================================
    // SITE CONTENT
    // ==================================================

    match /content/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Cloud Functions use the Admin SDK and bypass these rules.
    // Browser clients must never read or write view-deduplication records.
    match /listingViewEvents/{eventId} {
      allow read, write: if false;
    }

    // Block all unknown collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
