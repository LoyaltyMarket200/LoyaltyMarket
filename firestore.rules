rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == "princeteah200@gmail.com";
    }

    function userProfileExists() {
      return isSignedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function currentUserProfile() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function isActiveUser() {
      return isSignedIn()
        && userProfileExists()
        && (
          !currentUserProfile().keys().hasAny(["suspended"])
          || currentUserProfile().suspended != true
        );
    }

    // ==========================================
    // USERS
    // ==========================================

    match /users/{userId} {

      // Public seller and business profiles
      allow read: if true;

      // Users can create only their own personal profile.
      // Trust badges and elevated account types are admin-controlled.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.verified == false
        && request.resource.data.businessVerified == false
        && request.resource.data.get("isBusinessVerified", false) == false
        && request.resource.data.get("resellerVerified", false) == false
        && request.resource.data.get("isResellerVerified", false) == false
        && request.resource.data.suspended == false
        && request.resource.data.get("accountType", "personal") == "personal"
        && (
          request.resource.data.role == "user"
          || (isAdmin() && request.resource.data.role == "admin")
        );

      // Admin can update every user field.
      // Normal users may edit profile/application information, but cannot
      // approve themselves or change protected account/verification fields.
      allow update: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "verified",
            "businessVerified",
            "isBusinessVerified",
            "resellerVerified",
            "isResellerVerified",
            "suspended",
            "role",
            "email",
            "accountType",
            "businessReviewedBy",
            "businessReviewedAt",
            "resellerReviewedBy",
            "resellerReviewedAt",
            "sellerVerificationReviewedBy",
            "sellerVerificationReviewedAt"
          ])
          && request.resource.data.get("businessApplicationStatus", "")
            in [resource.data.get("businessApplicationStatus", ""), "pending"]
          && request.resource.data.get("resellerApplicationStatus", "")
            in [resource.data.get("resellerApplicationStatus", ""), "pending"]
          && request.resource.data.get("sellerVerificationStatus", "")
            in [resource.data.get("sellerVerificationStatus", ""), "pending"]
        );

      // Only admin can delete profiles
      allow delete: if isAdmin();
    }

    // ==========================================
    // PRODUCTS / LISTINGS
    // ==========================================

    match /products/{productId} {

      // Listings are publicly viewable
      allow read: if true;

      // Active users can create their own listings
      allow create: if isActiveUser()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.sellerEmail
          == request.auth.token.email
        && request.resource.data.status == "pending_review"
        && request.resource.data.featured != true;

      // Admin can update all listing information.
      // Sellers can manage only their own listings.
      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.sellerId == request.auth.uid

          && request.resource.data.sellerId
            == resource.data.sellerId

          && request.resource.data.sellerEmail
            == resource.data.sellerEmail

          && request.resource.data.boostStatus
            in [
              resource.data.boostStatus,
              "pending"
            ]

          && (
            request.resource.data.featured
              == resource.data.featured
            || request.resource.data.featured == false
          )

          && request.resource.data.boostExpiresAt
            == resource.data.boostExpiresAt

          && (
            resource.data.status != "pending_review"
            || request.resource.data.status
              == "pending_review"
          )
        );

      // Listing owner or admin can delete
      allow delete: if isAdmin()
        || (
          isActiveUser()
          && resource.data.sellerId == request.auth.uid
        );
    }

    // ==========================================
    // MESSAGES
    // ==========================================

    match /messages/{messageId} {

      // Sender must be the authenticated user
      allow create: if isActiveUser()
        && request.resource.data.senderId
          == request.auth.uid
        && request.resource.data.receiverId
          != request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAll([
          request.resource.data.senderId,
          request.resource.data.receiverId
        ]);

      // Only participants or admin can read
      allow read: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid
            in resource.data.participants
        );

      // Participants may only change read fields
      allow update: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid
            in resource.data.participants

          && request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              "read",
              "readAt"
            ])
        );

      // Only admin can delete messages
      allow delete: if isAdmin();
    }

    // ==========================================
    // REVIEWS
    // ==========================================

    match /reviews/{reviewId} {

      // Reviews are publicly viewable
      allow read: if true;

      // Users cannot review themselves
      allow create: if isActiveUser()
        && request.resource.data.reviewerId
          == request.auth.uid
        && request.resource.data.sellerId
          != request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Review owner or admin can update
      allow update: if isAdmin()
        || (
          isActiveUser()
          && resource.data.reviewerId
            == request.auth.uid

          && request.resource.data.reviewerId
            == resource.data.reviewerId

          && request.resource.data.sellerId
            == resource.data.sellerId

          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
        );

      // Review owner or admin can delete
      allow delete: if isAdmin()
        || (
          isActiveUser()
          && resource.data.reviewerId
            == request.auth.uid
        );
    }

    // ==========================================
    // FOLLOWERS
    // ==========================================

    match /followers/{followId} {

      // Anyone can see follower counts and status
      allow read: if true;

      // Active users can follow another seller
      allow create: if isActiveUser()
        && request.resource.data.followerId
          == request.auth.uid
        && request.resource.data.sellerId is string
        && request.resource.data.sellerId
          != request.auth.uid
        && followId
          == request.resource.data.sellerId
            + "_"
            + request.auth.uid
        && request.resource.data.keys().hasOnly([
          "sellerId",
          "followerId",
          "createdAt"
        ]);

      // Follow records should not be edited
      allow update: if false;

      // Users can unfollow only themselves
      allow delete: if isAdmin()
        || (
          isActiveUser()
          && resource.data.followerId
            == request.auth.uid
        );
    }

    // ==========================================
    // REPORTS
    // ==========================================

    match /reports/{reportId} {

      // Active users can submit reports
      allow create: if isActiveUser()
        && request.resource.data.status == "pending"
        && (
          (
            request.resource.data.keys().hasAll([
              "userId",
              "fullName",
              "email",
              "reportType",
              "description",
              "status",
              "createdAt"
            ])

            && request.resource.data.userId
              == request.auth.uid

            && request.resource.data.description
              is string

            && request.resource.data.description.size() > 0
          )

          ||

          (
            request.resource.data.keys().hasAll([
              "reporterId",
              "sellerId",
              "status"
            ])

            && request.resource.data.reporterId
              == request.auth.uid

            && request.resource.data.sellerId
              != request.auth.uid
          )
        );

      // Only admin can view and manage reports
      allow read, update, delete: if isAdmin();
    }

    // ==========================================
    // WISHLISTS
    // ==========================================

    match /wishlists/{userId}/items/{itemId} {

      // Users control only their own wishlist
      allow read, create, update, delete:
        if isActiveUser()
        && request.auth.uid == userId;
    }

    // ==========================================
    // NOTIFICATIONS
    // ==========================================

    match /notifications/{notificationId} {

      // Active users can create notifications
      allow create: if isActiveUser()
        && request.resource.data.userId is string;

      // Notification owner or admin can read
      allow read: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid
            == resource.data.userId
        );

      // Notification owner may update it
      allow update: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid
            == resource.data.userId

          && request.resource.data.userId
            == resource.data.userId
        );

      // Notification owner or admin can delete
      allow delete: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid
            == resource.data.userId
        );
    }

    // ==========================================
    // ORDERS
    // ==========================================

    match /orders/{orderId} {

      // Buyer creates a pending order
      allow create: if isActiveUser()
        && request.resource.data.buyerId
          == request.auth.uid
        && request.resource.data.sellerId
          != request.auth.uid
        && request.resource.data.status
          == "pending";

      // Buyer, seller, or admin can view
      allow read: if isAdmin()
        || (
          isActiveUser()
          && (
            request.auth.uid
              == resource.data.buyerId

            || request.auth.uid
              == resource.data.sellerId
          )
        );

      // Admin can update any order
      allow update: if isAdmin()

        // Buyer can cancel a pending order
        || (
          isActiveUser()
          && request.auth.uid
            == resource.data.buyerId

          && request.resource.data.buyerId
            == resource.data.buyerId

          && request.resource.data.sellerId
            == resource.data.sellerId

          && resource.data.status == "pending"
          && request.resource.data.status
            == "cancelled"
        )

        // Seller can confirm or cancel pending order
        // and complete or cancel confirmed order
        || (
          isActiveUser()
          && request.auth.uid
            == resource.data.sellerId

          && request.resource.data.buyerId
            == resource.data.buyerId

          && request.resource.data.sellerId
            == resource.data.sellerId

          && (
            (
              resource.data.status == "pending"
              && request.resource.data.status
                in ["confirmed", "cancelled"]
            )

            ||

            (
              resource.data.status == "confirmed"
              && request.resource.data.status
                in ["completed", "cancelled"]
            )
          )
        );

      // Only admin can delete orders
      allow delete: if isAdmin();
    }


    // ==========================================
    // RESELLER APPLICATIONS
    // ==========================================

    match /resellerApplications/{userId} {

      // The applicant and admin can read the application.
      allow read: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && resource.data.userId == request.auth.uid
        );

      // An active user can create only their own pending application.
      allow create: if isActiveUser()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == "pending"
        && request.resource.data.permissionAgreement == true
        && request.resource.data.canRepresentMultipleOwners == true
        && request.resource.data.resellerName is string
        && request.resource.data.resellerName.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.county is string
        && request.resource.data.county.size() > 0
        && request.resource.data.city is string
        && request.resource.data.city.size() > 0
        && request.resource.data.categories is list
        && request.resource.data.categories.size() > 0
        && request.resource.data.experienceYears is number
        && request.resource.data.experienceYears >= 0
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.ownerPlan is string
        && request.resource.data.ownerPlan.size() > 0
        && request.resource.data.commissionPlan is string
        && request.resource.data.commissionPlan.size() > 0;

      // Admin can review any application.
      // The applicant may update only their own application and may never
      // approve themselves or change administrator review information.
      allow update: if isAdmin()
        || (
          isActiveUser()
          && request.auth.uid == userId
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.email == resource.data.email
          && resource.data.status in [
            "pending",
            "more_information_required"
          ]
          && request.resource.data.status == "pending"
          && request.resource.data.permissionAgreement == true
          && request.resource.data.canRepresentMultipleOwners == true
          && !request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasAny([
              "reviewedAt",
              "reviewedBy",
              "adminNote",
              "approvedAt",
              "approvedBy"
            ])
        );

      // Only admin can remove application records.
      allow delete: if isAdmin();
    }

    // ==========================================
    // MARKETPLACE SETTINGS
    // ==========================================

    match /settings/{settingId} {

      // Website can read marketplace settings
      allow read: if true;

      // Only admin can change settings
      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // SITE CONTENT (FAQ, Terms, Privacy, Safety, etc.)
    // ==========================================

    match /content/{pageId} {

      // Website can read site content pages
      allow read: if true;

      // Only admin can change site content
      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // BLOCK UNKNOWN COLLECTIONS
    // ==========================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
